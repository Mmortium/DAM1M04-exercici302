{{> header}}
{{> menu}}

<main class="container">
    <h1>Benvingut a {{common.project}}</h1>
    
    <section>
        <h2>Top 5 Pel·lícules</h2>
        <div class="grid">
            {{#each movies}}
            <div class="card">
                <img src="/imatges/peli.png" alt="caràtula" style="width:100%">
                <h3>{{this.title}}</h3>
                <p>Any: {{this.release_year}}</p>
            </div>
            {{/each}}
        </div>
    </section>

    <section>
        <h2>Categories</h2>
        <ul class="category-list">
            {{#each categories}}
            <li>{{this.name}}</li>
            {{/each}}
        </ul>
    </section>
</main>

{{> footer}}