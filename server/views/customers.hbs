{{> header}}
{{> menu}}

<main class="container">
    <header>
        <h1>Llista de Clients (Top 25)</h1>
        <p>A continuació es mostren els clients i els seus 5 lloguers més recents.</p>
    </header>

    <div class="customers-list">
        {{#each customers}}
        <article class="customer-item">
            <h3>{{this.first_name}} {{this.last_name}}</h3>
            <p class="email">Email: {{this.email}}</p>
            
            <div class="rentals-box">
                <strong>Últims 5 lloguers:</strong>
                <ul class="rentals-list">
                    {{#each this.rentals}}
                        {{!-- Aquí iteramos sobre el array de alquileres de cada cliente --}}
                        <li>🎥 {{this.title}}</li>
                    {{else}}
                        {{!-- Esto se muestra si el array rentals está vacío --}}
                        <li class="no-rentals">Sense lloguers recents</li>
                    {{/each}}
                </ul>
            </div>
            <hr>
        </article>
        {{/each}}
    </div>
</main>

{{> footer}}