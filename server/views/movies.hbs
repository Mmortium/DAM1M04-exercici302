{{> header}}
{{> menu}}

<main class="container">
    <header>
        <h1>Pel·lícules</h1>
        <p>Llistat de les 15 primeres pel·lícules amb els seus actors.</p>
    </header>

    <section class="movies-grid">
        {{#each movies}}
        <article class="movie-card">
            {{!-- Imagen genérica según estructura public/imatges/peli.png --}}
            <div class="movie-poster">
                <img src="/imatges/peli.png" alt="Caràtula de {{this.title}}">
            </div>
            
            <div class="movie-content">
                <h2>{{this.title}}</h2>
                <span class="year">Any: {{this.release_year}}</span>
                
                <div class="actors-box">
                    <strong>Actors:</strong>
                    <p>{{this.actors}}</p>
                </div>
            </div>
        </article>
        {{/each}}
    </section>
</main>

{{> footer}}